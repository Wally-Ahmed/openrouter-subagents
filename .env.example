# Copy this file to `.env` and fill in your real key:
#   cp .env.example .env
#
# `.env` is gitignored and must NEVER be committed. Only this placeholder
# template is tracked in git. Get a key at https://openrouter.ai/keys

OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional attribution headers OpenRouter uses for its app rankings (both optional;
# safe to leave commented out):
# OPENROUTER_SITE_URL=https://github.com/Wally-Ahmed/openrouter-subagents
# OPENROUTER_APP_NAME=openrouter-subagents

# Optional: override OpenRouter Fusion's built-in default panel + judge. Applies
# ONLY to the default model (openrouter/fusion). A per-call analysis_models /
# judge_model on the ask_openrouter tool still takes precedence over these, and
# these are ignored for any non-fusion model. Leave commented to use OpenRouter's
# Quality preset.
#   - Panel: comma-separated list of 1-8 OpenRouter model ids that answer in parallel.
#   - Judge: a single model id that synthesizes the panel's answers.
# OPENROUTER_FUSION_ANALYSIS_MODELS=anthropic/claude-opus-latest,openai/gpt-latest,google/gemini-pro-latest
# OPENROUTER_FUSION_JUDGE_MODEL=anthropic/claude-opus-latest
